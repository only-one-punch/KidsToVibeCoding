# ===========================================
# CodeBuddyAI 环境变量配置模板
# ===========================================
# 复制此文件为 .env 并填入实际值

# -------------------------------------------
# 数据库配置
# -------------------------------------------
DATABASE_URL=postgresql+asyncpg://codebuddy:codebuddy123@localhost:5432/codebuddy
REDIS_URL=redis://localhost:6379/0

# -------------------------------------------
# JWT 认证配置
# -------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -------------------------------------------
# AI 服务配置
# -------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=your-pinecone-environment
PINECONE_INDEX_NAME=codebuddy-knowledge

# -------------------------------------------
# 讯飞语音服务配置
# -------------------------------------------
XFYUN_APP_ID=your-xfyun-app-id
XFYUN_API_KEY=your-xfyun-api-key
XFYUN_API_SECRET=your-xfyun-api-secret

# -------------------------------------------
# 服务间认证
# -------------------------------------------
SERVICE_API_KEY=your-service-api-key-for-internal-communication

# -------------------------------------------
# 服务端口配置
# -------------------------------------------
GATEWAY_PORT=8000
USER_SERVICE_PORT=8001
LEARNING_SERVICE_PORT=8002
AI_ASSISTANT_PORT=8003
MULTIMODAL_PORT=8004
SANDBOX_PORT=8005

# -------------------------------------------
# 前端配置
# -------------------------------------------
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000/api/v1

# -------------------------------------------
# 日志配置
# -------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# -------------------------------------------
# 开发环境标识
# -------------------------------------------
ENVIRONMENT=development
DEBUG=true
